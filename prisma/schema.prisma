generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model WebhookLog {
  id        String   @id @default(cuid())
  source    String   // 'exotel', 'github', etc.
  payload   String   // JSON stringified payload
  action    String?  // Description of the action taken
  status    String   // 'success', 'pending', 'failed'
  error     String?  // Error message if any
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  key       String   @id // e.g., 'CODA_API_TOKEN'
  value     String
  updatedAt DateTime @updatedAt
}

model StudentMaster {
  id                  String          @id @default(cuid())
  codaRowId           String          @unique // Native Coda ID for updates
  studentName         String
  whatsappContact     String?
  email               String?
  email2              String?
  phone2              String?
  parentName          String?
  dateOfBirth         String?
  
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  
  // Relation to Schedule Events
  scheduleEvents      ScheduleEvent[]
}

model ScheduleEvent {
  id                  String          @id @default(cuid())
  codaRowId           String          @unique // Native Coda ID for updates
  day                 String?
  timeSlot            String?
  teacher             String?
  eventDate           DateTime?
  eventStatus         String?
  eventType           String?
  instrument          String?
  remark              String?
  attendanceStatus    String?
  attendanceReport    String?
  courseCode          String?
  phoneTrial          String?
  
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // Relation binding it to the Student Master
  studentId           String?
  student             StudentMaster?  @relation(fields: [studentId], references: [id])
}
